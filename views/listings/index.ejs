<% layout('/layouts/boilerplate') -%>

    <style>
        #filters {
            display: flex;
            flex-wrap: wrap;

        }

        .filters {
            text-align: center;
            margin-right: 2rem;
            margin-top: 1.5rem;
            opacity: 0.8;
        }

        .filters:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filters p {
            font-size: 0.9rem;
        }

        #filters a {
            text-decoration: none;
            color: inherit;
        }

        .tax-info {
            display: none;
        }
        .tax-toggle{
            border: 0.1mm solid black;
            border-radius: 1rem;
            height: 4rem;
            padding: 1rem;
            margin-top: 1rem;
            margin-left: 3rem;
            display: flex;
            align-items: center;
        }
    </style>

    <div id="filters">

        <a href="/listings?category=Trending">
            <div class="filters">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </div>
        </a>

        <a href="/listings?category=Rooms">
            <div class="filters">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </div>
        </a>

        <a href="/listings?category=Apartments">
            <div class="filters">
                <div><i class="fa-solid fa-hotel"></i></div>
                <p>Apartments</p>
            </div>
        </a>

        <a href="/listings?category=Villas">
            <div class="filters">
                <div><i class="fa-solid fa-building-columns"></i></div>
                <p>Villas</p>
            </div>
        </a>

        <a href="/listings?category=Iconic Cities">
            <div class="filters">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Iconic Cities</p>
            </div>
        </a>

        <a href="/listings?category=Beach">
            <div class="filters">
                <div><i class="fa-solid fa-umbrella-beach"></i></div>
                <p>Beach</p>
            </div>
        </a>

        <a href="/listings?category=Amazing Pools">
            <div class="filters">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Amazing Pools</p>
            </div>
        </a>

        <a href="/listings?category=Camping">
            <div class="filters">
                <div><i class="fa-solid fa-tents"></i></div>
                <p>Camping</p>
            </div>
        </a>

        <a href="/listings?category=Farms">
            <div class="filters">
                <div><i class="fa-solid fa-cow"></i></div>
                <p>Farms</p>
            </div>
        </a>

        <a href="/listings?category=Arctic">
            <div class="filters">
                <div><i class="fa-regular fa-snowflake"></i></div>
                <p>Arctic</p>
            </div>
        </a>

        <a href="/listings?category=Ferries">
            <div class="filters">
                <div><i class="fa-solid fa-sailboat"></i></div>
                <p>Ferries</p>
            </div>
        </a>

        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after Taxes</label>
            </div>
        </div>

    </div>


    <body>
        <div class="row row-cols-lg-4 row-cols-md-2 row-cols-sm-1 mt-3">
            <% for ( let listing of allListings) { %>
                <a href="/listings/<%=listing._id%>" class="listing-link">
                    <div class="card col listing-card">
                        <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image"
                            style="height:15rem;">
                        <div class="card-img-overlay">
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%=listing.title%>
                                </b> <br>
                                &#8377;
                                <%= listing.price?.toLocaleString("en-IN") || "N/A" %>/night
                                    <i class="tax-info">&nbsp;+18% GST</i>
                            </p>
                        </div>

                    </div>
                    <% }%>
                </a>
        </div>
    </body>

    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("click", () => {
            let taxInfo = document.getElementsByClassName("tax-info")
            for (info of taxInfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline"
                }
                else {
                    info.style.display = "none"
                }
            }
        })
    </script>