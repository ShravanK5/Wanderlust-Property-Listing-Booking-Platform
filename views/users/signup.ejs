<% layout('/layouts/boilerplate') -%>


<body>
    <div class="row mt-3">
        <h2 class="col-6 offset-3">Signup on Wanderlust!</h2>
            <div class="col-6 offset-3">
                <form action="/signup" method="POST" class="needs-validation" novalidate>
                    <div class="mb-3 mt-1">
                        <label for="username" class="form-label">Username</label>
                        <input name="username" id="username" placeholder="Add a catchy username" type="text" class="form-control"
                            required />
                        <div class="valid-feedback">Username looks good!</div>
                        <div class="invalid-feedback">Please enter a Username</div>
                    </div>
                    <div class="mb-3 mt-1">
                        <label for="email" class="form-label">Email</label>
                        <input name="email" id="email" placeholder="Add your email" type="email" class="form-control"
                            required />
                        <div class="valid-feedback">Valid</div>
                        <div class="invalid-feedback">Please enter a valid email</div>
                    </div>
                    <div class="mb-3 mt-1">
                        <label for="password" class="form-label">Password</label>
                        <input name="password" id="password" placeholder="Add a catchy password" type="password" class="form-control"
                            required />
                        <div class="valid-feedback">Valid!</div>
                        <div class="invalid-feedback">Please enter a password</div>
                    </div>
                    <button class="btn btn-dark add-btn">Signup</button>
                </form>
                </div>
                </div>
</body>