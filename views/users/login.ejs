<% layout('/layouts/boilerplate') -%>

<body>
    <div class="row mt-3">
        <h2 class="col-6 offset-3">Login into Your Account!</h2>
            <div class="col-6 offset-3">
                <form action="/login" method="POST" class="needs-validation" novalidate>
                    <div class="mb-3 mt-1">
                        <label for="username" class="form-label">Username</label>
                        <input name="username" id="username" placeholder="Enter your username" type="text" class="form-control"
                            required />
                    </div>
                    
                    <div class="mb-3 mt-1">
                        <label for="password" class="form-label">Password</label>
                        <input name="password" id="password" placeholder="Enter your password" type="password" class="form-control"
                            required />
                    </div>
                    <button class="btn btn-dark add-btn">Login</button>
                </form>
                </div>
                </div>
</body>